{
  "name": "mainmatter-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --cache --fix",
    "lint:md": "prettier --check **/*.md",
    "lint:md:fix": "prettier --write **/*.md",
    "lint:sass": "prettier --check **/*.scss",
    "lint:sass:fix": "prettier --write **/*.scss",
    "lint:njk": "prettier --check **/*.njk",
    "lint:njk:fix": "prettier --write **/*.njk",
    "lint": "pnpm run --parallel \"/^lint:[^:]+$/\"",
    "fix": "pnpm run --parallel \"/^lint:.+:fix$/\"",
    "build": "pnpm run build:html && pnpm run build:sass && pnpm run build:js",
    "build:html": "astro build",
    "build:js": "rollup --config ./rollup.config.mjs",
    "build:sass": "sass src/assets/css/app.scss ./dist/assets/css/app.css --style=compressed",
    "check": "astro check",
    "dev": "pnpm run build && astro preview --host 0.0.0.0",
    "watch:js": "rollup --config ./rollup.config.mjs --watch",
    "watch:sass": "sass src/assets/css/app.scss ./dist/assets/css/app.css --style=compressed --watch",
    "watch": "pnpm run --parallel \"/^watch:/\"",
    "percy:build": "pnpm run build && pnpm run percy:disable-lazy-images",
    "percy:disable-lazy-images": "replace-in-file --configFile=.percy-disable-lazy-loading.js",
    "percy": "percy snapshot",
    "crawl": "node scripts/crawl.js",
    "this-week": "twios/this-week-in-open-source --config-path=config/this-week-in-open-source.config.json"
  },
  "devDependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@astrojs/check": "^0.9.9",
    "@lhci/cli": "^0.14.0",
    "@percy/cli": "^1.31.12",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@tbranyen/jsdom": "13.0.0",
    "astro": "^6.3.5",
    "broken-link-checker": "^0.7.8",
    "colors": "^1.4.0",
    "dayjs": "^1.11.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "markdown-it": "14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "nunjucks": "^3.2.4",
    "prettier": "3.4.2",
    "prettier-plugin-jinja-template": "^2.1.0",
    "replace-in-file": "^7.2.0",
    "rollup": "^4.60.2",
    "sass": "^1.99.0",
    "slugify": "1.6.6",
    "svgo": "^3.3.3",
    "typescript": "^6.0.3",
    "wicg-inert": "^3.1.3"
  },
  "browserslist": [
    "last 1 Chrome versions",
    "last 1 Firefox versions",
    "last 1 Safari versions",
    "last 1 Edge versions"
  ],
  "dependencies": {
    "@sentry/browser": "^9.47.1",
    "gsap": "^3.15.0",
    "lax.js": "^2.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "22.15.0",
    "pnpm": "9.15.4"
  },
  "packageManager": "pnpm@9.15.4"
}
